# Unir arquivos DOC via PS

powershell -Command ^
"$word = New-Object -ComObject Word.Application; ^
$word.Visible = $false; ^
$doc = $word.Documents.Add(); ^
Get-ChildItem -Path 'C:\docs' -Filter *.docx | Sort-Object Name | ForEach-Object { ^
    $range = $doc.Content; ^
    $range.Collapse(0); ^
    $range.InsertFile($_.FullName); ^
    $range.InsertParagraphAfter(); ^
}; ^
$doc.SaveAs('C:\docs\unido.docx'); ^
$doc.Close(); ^
$word.Quit()"
